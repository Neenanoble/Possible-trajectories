Cell[BoxData[{
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"x_", ",", "y_", ",", "vx_", ",", "vy_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x", "-", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}], "*", 
       RowBox[{"(", 
        RowBox[{"x", "+", "\[Mu]"}], ")"}]}], 
      SuperscriptBox[
       RowBox[{"r1", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "3"]], "-", 
     FractionBox[
      RowBox[{"\[Mu]", "*", 
       RowBox[{"(", 
        RowBox[{"x", "+", "\[Mu]", "-", "1"}], ")"}]}], 
      SuperscriptBox[
       RowBox[{"r2", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "3"]], "+", 
     RowBox[{"2", " ", "vy"}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "2"}], " ", "vx"}], "+", "y", "-", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}], "*", "y"}], 
      SuperscriptBox[
       RowBox[{"r1", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "3"]], "-", 
     FractionBox[
      RowBox[{"\[Mu]", "*", "y"}], 
      SuperscriptBox[
       RowBox[{"r2", "[", 
        RowBox[{"x", ",", "y"}], "]"}], "3"]]}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"r1", "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"x", "+", "\[Mu]"}], ")"}], "2"], "+", 
     SuperscriptBox["y", "2"]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r2", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{"Sqrt", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"x", "-", 
       RowBox[{"(", 
        RowBox[{"1", "-", "\[Mu]"}], ")"}]}], ")"}], "2"], "+", 
    SuperscriptBox["y", "2"]}], "]"}]}]}], "Input",
