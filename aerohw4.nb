Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"spcorb", "=", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "t", "]"}], ",", 
        RowBox[{"y", "[", "t", "]"}]}], "}"}], "/.", " ", "transfer"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tsc"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}], ",", 
     RowBox[{"PlotLegends", "->", "\"\<Sc\>\""}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"moonorb", "=", 
   RowBox[{"ParametricPlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"xm", "[", "t", "]"}], ",", 
        RowBox[{"ym", "[", "t", "]"}]}], "}"}], "/.", " ", "transfer"}], ",", 
     
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "tsc"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotStyle", "->", "Red"}]}], "]"}]}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"spcorb", ",", "moonorb"}], "}"}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Spacecraft\>\"", ",", "\"\<Moon\>\""}], "}"}]}]}], 
  "]"}]}], "Input",
