  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tm", " ", "=", " ", 
   RowBox[{"2", "\[Pi]", " ", 
    RowBox[{"Sqrt", "[", 
     FractionBox[
      SuperscriptBox["am", "3"], 
      RowBox[{"\[Mu]e", " "}]], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
