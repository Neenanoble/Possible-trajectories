         RowBox[{"y", "[", "t", "]"}]}], 
        SuperscriptBox[
         RowBox[{"r2", "[", "t", "]"}], "3"]]}]}], ",", 
     RowBox[{
      RowBox[{"r1", "[", "t", "]"}], "==", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "+", "\[Mu]"}], ")"}], "2"], "+", 
        SuperscriptBox[
         RowBox[{"y", "[", "t", "]"}], "2"]}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"r2", "[", "t", "]"}], "==", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "-", 
           RowBox[{"(", 
            RowBox[{"1", "-", "\[Mu]"}], ")"}]}], ")"}], "2"], "+", 
        SuperscriptBox[
         RowBox[{"y", "[", "t", "]"}], "2"]}], "]"}]}]}], "}"}]}], 
  ";"}]}], "Input",
