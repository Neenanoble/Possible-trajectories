Cell[BoxData[{
 RowBox[{
  RowBox[{"transfer", "=", 
   RowBox[{
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"x", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          FractionBox[
           RowBox[{"-", "\[Mu]e"}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"x", "[", "t", "]"}], "2"], "+", 
              SuperscriptBox[
               RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
            RowBox[{"3", "/", "2"}]]], 
          RowBox[{"x", "[", "t", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "''"}], "[", "t", "]"}], "==", 
         RowBox[{
          FractionBox[
           RowBox[{"-", "\[Mu]e"}], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"x", "[", "t", "]"}], "2"], "+", 
              SuperscriptBox[
               RowBox[{"y", "[", "t", "]"}], "2"]}], ")"}], 
            RowBox[{"3", "/", "2"}]]], 
          RowBox[{"y", "[", "t", "]"}]}]}], ",", 
        RowBox[{
         RowBox[{"x", "[", "0", "]"}], "==", "rp"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"x", "'"}], "[", "0", "]"}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"y", "'"}], "[", "0", "]"}], "==", "vp"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "tsc"}], "}"}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xm", "[", "t_", "]"}], ":=", " ", 
  RowBox[{"am", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"nm", " ", "t"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ym", "[", "t_", "]"}], ":=", " ", 
  RowBox[{"am", " ", 
   RowBox[{"Sin", "[", 
    RowBox[{"nm", " ", "t"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.985554271096311*^9, 3.9855543022534018`*^9}, 
