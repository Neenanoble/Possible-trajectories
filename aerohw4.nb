        FractionBox[
         SuperscriptBox["am", "3"], 
         RowBox[{"\[Mu]e", " "}]], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"TU", "=", 
      RowBox[{"TM", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "Pi"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
